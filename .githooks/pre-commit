#!/usr/bin/env bash
# Auto-bump the BUILD_BUST marker in a worker's build.sh whenever its sibling
# environment.yml is staged.
#
# Why: MAAP rebuilds an algo image on every register, but the expensive conda
# layer cache-hits when build.sh content is unchanged — so a dep added to
# environment.yml without a build.sh change can silently never install, and the
# worker dies at runtime with ModuleNotFoundError / missing GDAL plugin. Tying a
# dep change to a build.sh change forces the conda layer to rebuild.
# See PIPELINE_TEMPLATE.md gotcha "A dep in environment.yml can still be missing".
#
# Enable in each clone (local + MAAP Jupyter) with:
#     git config core.hooksPath .githooks
#
# Deliberately bash-3.2 / POSIX-friendly (no mapfile) so it runs on macOS too.

today=$(date -u +%Y-%m-%d)

env_files=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '(^|/)\.maap/[^/]+/environment\.yml$')
[ -z "$env_files" ] && exit 0

echo "$env_files" | while IFS= read -r env_file; do
    [ -z "$env_file" ] && continue
    build="$(dirname "$env_file")/build.sh"
    if [ ! -f "$build" ]; then
        echo "pre-commit: $env_file staged but no sibling build.sh — skipping bump"
        continue
    fi
    cur=$(grep -oE "BUILD_BUST=[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]+" "$build" | head -1 | sed 's/BUILD_BUST=//')
    if [ -z "$cur" ]; then
        echo "pre-commit: WARNING — $build has no 'BUILD_BUST=YYYY-MM-DD-N' marker; not bumping"
        continue
    fi
    if [ "${cur%-*}" = "$today" ]; then
        n=$(( ${cur##*-} + 1 ))     # already bumped today — increment the suffix
    else
        n=1
    fi
    new="${today}-${n}"
    perl -pi -e "s/BUILD_BUST=[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]+/BUILD_BUST=${new}/" "$build"
    git add "$build"
    echo "pre-commit: bumped ${build} BUILD_BUST -> ${new} (environment.yml changed)"
done

exit 0
